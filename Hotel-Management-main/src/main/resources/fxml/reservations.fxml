<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.TableColumn?>
<?import javafx.scene.control.TableView?>
<?import javafx.scene.layout.BorderPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.Region?>
<?import javafx.scene.layout.VBox?>

<BorderPane xmlns="http://javafx.com/javafx"
            xmlns:fx="http://javafx.com/fxml"
            fx:controller="com.cse241.hotel.ui.controller.ReservationManagementController"
            styleClass="page">

    <top>
        <HBox styleClass="app-header" alignment="CENTER_LEFT" spacing="12">
            <padding>
                <Insets top="14" right="20" bottom="14" left="20"/>
            </padding>
            <Button text="← Back" onAction="#onBack" styleClass="ghost-button"/>
            <Label text="My reservations" styleClass="header-title"/>
            <Region HBox.hgrow="ALWAYS"/>
            <Button text="Refresh" onAction="#onRefresh" styleClass="ghost-button"/>
        </HBox>
    </top>

    <center>
        <VBox spacing="14" styleClass="card-wrap">
            <padding>
                <Insets top="20" right="24" bottom="20" left="24"/>
            </padding>

            <TableView fx:id="table" VBox.vgrow="ALWAYS" styleClass="data-table">
                <columns>
                    <TableColumn fx:id="idCol" text="Reservation #" prefWidth="120"/>
                    <TableColumn fx:id="roomCol" text="Room" prefWidth="180"/>
                    <TableColumn fx:id="checkInCol" text="Check-in" prefWidth="120"/>
                    <TableColumn fx:id="checkOutCol" text="Check-out" prefWidth="120"/>
                    <TableColumn fx:id="statusCol" text="Status" prefWidth="120"/>
                </columns>
                <columnResizePolicy>
                    <TableView fx:constant="CONSTRAINED_RESIZE_POLICY"/>
                </columnResizePolicy>
            </TableView>

            <HBox alignment="CENTER_LEFT" spacing="12">
                <Label fx:id="statusLabel" styleClass="status-label"/>
                <Region HBox.hgrow="ALWAYS"/>
                <Button fx:id="confirmButton" text="Confirm" onAction="#onConfirm" styleClass="secondary-button"/>
                <Button fx:id="cancelButton" text="Cancel" onAction="#onCancel" styleClass="danger-button"/>
                <Button fx:id="payButton" text="Checkout / Pay" onAction="#onPay" styleClass="primary-button"/>
            </HBox>
        </VBox>
    </center>
</BorderPane>
