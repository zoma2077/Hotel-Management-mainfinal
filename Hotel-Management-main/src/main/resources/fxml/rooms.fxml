<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.ChoiceBox?>
<?import javafx.scene.control.DatePicker?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.TableColumn?>
<?import javafx.scene.control.TableView?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.BorderPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.Region?>
<?import javafx.scene.layout.VBox?>

<BorderPane xmlns="http://javafx.com/javafx"
            xmlns:fx="http://javafx.com/fxml"
            fx:controller="com.cse241.hotel.ui.controller.RoomBrowseController"
            styleClass="page">

    <top>
        <HBox styleClass="app-header" alignment="CENTER_LEFT" spacing="12">
            <padding>
                <Insets top="14" right="20" bottom="14" left="20"/>
            </padding>
            <Button text="← Back" onAction="#onBack" styleClass="ghost-button"/>
            <Label text="Browse rooms" styleClass="header-title"/>
            <Region HBox.hgrow="ALWAYS"/>
        </HBox>
    </top>

    <center>
        <VBox spacing="14" styleClass="card-wrap">
            <padding>
                <Insets top="20" right="24" bottom="20" left="24"/>
            </padding>

            <VBox spacing="10" styleClass="card">
                <padding>
                    <Insets top="16" right="20" bottom="16" left="20"/>
                </padding>
                <Label text="Filters" styleClass="section-title"/>
                <HBox spacing="14" alignment="CENTER_LEFT">
                    <VBox spacing="4">
                        <Label text="Room type" styleClass="field-label"/>
                        <ChoiceBox fx:id="typeChoice" prefWidth="160"/>
                    </VBox>
                    <VBox spacing="4">
                        <Label text="Max nightly rate ($)" styleClass="field-label"/>
                        <TextField fx:id="maxPriceField" promptText="e.g. 150" prefWidth="160"/>
                    </VBox>
                    <VBox spacing="4">
                        <Label text="Check-in" styleClass="field-label"/>
                        <DatePicker fx:id="checkInPicker" prefWidth="160"/>
                    </VBox>
                    <VBox spacing="4">
                        <Label text="Check-out" styleClass="field-label"/>
                        <DatePicker fx:id="checkOutPicker" prefWidth="160"/>
                    </VBox>
                </HBox>
                <VBox spacing="6">
                    <Label text="Required amenities" styleClass="field-label"/>
                    <HBox fx:id="amenitiesBox" spacing="12"/>
                </VBox>
                <HBox spacing="10">
                    <Button text="Apply filters" onAction="#onApplyFilters" styleClass="primary-button"/>
                    <Button text="Clear" onAction="#onClearFilters" styleClass="ghost-button"/>
                </HBox>
            </VBox>

            <TableView fx:id="roomsTable" VBox.vgrow="ALWAYS" styleClass="data-table">
                <columns>
                    <TableColumn fx:id="roomNumberCol" text="Room #" prefWidth="90"/>
                    <TableColumn fx:id="roomTypeCol" text="Type" prefWidth="120"/>
                    <TableColumn fx:id="capacityCol" text="Capacity" prefWidth="90"/>
                    <TableColumn fx:id="rateCol" text="Nightly rate" prefWidth="120"/>
                    <TableColumn fx:id="amenitiesCol" text="Amenities" prefWidth="240"/>
                </columns>
                <columnResizePolicy>
                    <TableView fx:constant="CONSTRAINED_RESIZE_POLICY"/>
                </columnResizePolicy>
            </TableView>

            <HBox alignment="CENTER_LEFT" spacing="12">
                <Label fx:id="statusLabel" styleClass="status-label"/>
                <Region HBox.hgrow="ALWAYS"/>
                <Button fx:id="reserveButton" text="Reserve selected" onAction="#onReserve"
                        styleClass="primary-button"/>
            </HBox>
        </VBox>
    </center>
</BorderPane>
