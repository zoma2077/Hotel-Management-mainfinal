<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.ChoiceBox?>
<?import javafx.scene.control.DatePicker?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.TableColumn?>
<?import javafx.scene.control.TableView?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.BorderPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.VBox?>

<BorderPane xmlns="http://javafx.com/javafx"
            xmlns:fx="http://javafx.com/fxml"
            fx:controller="com.cse241.hotel.ui.controller.ReceptionistReservationsController"
            styleClass="page">
    <top>
        <HBox spacing="12" alignment="CENTER_LEFT" styleClass="app-header">
            <padding>
                <Insets top="14" right="18" bottom="14" left="18"/>
            </padding>
            <Label text="Receptionist • Reservations" styleClass="header-title"/>
            <HBox HBox.hgrow="ALWAYS"/>
            <Button text="Chat" onAction="#onChat" styleClass="secondary-button"/>
            <Button text="Back" onAction="#onBack" styleClass="ghost-button"/>
        </HBox>
    </top>

    <center>
        <VBox spacing="14">
            <padding>
                <Insets top="16" right="18" bottom="18" left="18"/>
            </padding>

            <VBox spacing="10" styleClass="card">
                <padding>
                    <Insets top="14" right="14" bottom="14" left="14"/>
                </padding>

                <Label text="Search filters" styleClass="section-title"/>

                <HBox spacing="10">
                    <VBox spacing="6" HBox.hgrow="ALWAYS">
                        <Label text="Guest username" styleClass="field-label"/>
                        <TextField fx:id="guestUsernameField" promptText="e.g. alice"/>
                    </VBox>
                    <VBox spacing="6" HBox.hgrow="ALWAYS">
                        <Label text="Room number" styleClass="field-label"/>
                        <TextField fx:id="roomNumberField" promptText="e.g. 101"/>
                    </VBox>
                    <VBox spacing="6" HBox.hgrow="ALWAYS">
                        <Label text="Status" styleClass="field-label"/>
                        <ChoiceBox fx:id="statusChoice"/>
                    </VBox>
                </HBox>

                <HBox spacing="10">
                    <VBox spacing="6" HBox.hgrow="ALWAYS">
                        <Label text="From" styleClass="field-label"/>
                        <DatePicker fx:id="fromDatePicker"/>
                    </VBox>
                    <VBox spacing="6" HBox.hgrow="ALWAYS">
                        <Label text="To" styleClass="field-label"/>
                        <DatePicker fx:id="toDatePicker"/>
                    </VBox>
                    <HBox spacing="10" alignment="BOTTOM_LEFT">
                        <Button text="Search" onAction="#onSearch" styleClass="primary-button"/>
                        <Button text="Clear" onAction="#onClear" styleClass="secondary-button"/>
                    </HBox>
                    <HBox HBox.hgrow="ALWAYS"/>
                    <Label fx:id="statusLabel" text="" styleClass="status-label"/>
                </HBox>
            </VBox>

            <TableView fx:id="table" styleClass="data-table" prefHeight="420">
                <columns>
                    <TableColumn fx:id="idCol" text="ID"/>
                    <TableColumn fx:id="guestCol" text="Guest"/>
                    <TableColumn fx:id="roomCol" text="Room"/>
                    <TableColumn fx:id="datesCol" text="Dates"/>
                    <TableColumn fx:id="statusCol" text="Status"/>
                </columns>
            </TableView>

            <HBox spacing="10">
                <Button fx:id="checkInButton" text="Check-in (Confirm)" onAction="#onCheckIn" styleClass="primary-button"/>
                <Button fx:id="checkOutButton" text="Check-out (Complete)" onAction="#onCheckOut" styleClass="secondary-button"/>
                <Button fx:id="payButton" text="Initiate payment" onAction="#onPay" styleClass="secondary-button"/>
            </HBox>
        </VBox>
    </center>
</BorderPane>

