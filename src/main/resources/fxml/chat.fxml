<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<BorderPane xmlns="http://javafx.com/javafx"
            xmlns:fx="http://javafx.com/fxml"
            fx:controller="com.cse241.hotel.ui.controller.ChatController"
            styleClass="page">

    <top>
        <HBox styleClass="app-header" alignment="CENTER_LEFT" spacing="12">
            <padding>
                <Insets top="14" right="20" bottom="14" left="20"/>
            </padding>
            <Button text="Back" onAction="#onBack" styleClass="ghost-button"/>
            <Label text="Guest ↔ Receptionist Chat" styleClass="header-title"/>
            <Region HBox.hgrow="ALWAYS"/>
            <Label fx:id="statusLabel" styleClass="muted"/>
        </HBox>
    </top>

    <center>
        <VBox spacing="14" styleClass="card-wrap">
            <padding>
                <Insets top="24" right="40" bottom="24" left="40"/>
            </padding>

            <VBox spacing="12" styleClass="card" maxWidth="900">
                <padding>
                    <Insets top="18" right="18" bottom="18" left="18"/>
                </padding>

                <GridPane hgap="10" vgap="10">
                    <columnConstraints>
                        <ColumnConstraints percentWidth="14"/>
                        <ColumnConstraints percentWidth="30"/>
                        <ColumnConstraints percentWidth="14"/>
                        <ColumnConstraints percentWidth="42"/>
                    </columnConstraints>

                    <Label text="Host" GridPane.rowIndex="0" GridPane.columnIndex="0" styleClass="muted"/>
                    <TextField fx:id="hostField" GridPane.rowIndex="0" GridPane.columnIndex="1"/>

                    <Label text="Port" GridPane.rowIndex="0" GridPane.columnIndex="2" styleClass="muted"/>
                    <TextField fx:id="portField" GridPane.rowIndex="0" GridPane.columnIndex="3"/>

                    <Label text="Role" GridPane.rowIndex="1" GridPane.columnIndex="0" styleClass="muted"/>
                    <ChoiceBox fx:id="roleChoice" GridPane.rowIndex="1" GridPane.columnIndex="1"/>

                    <Label text="Username" GridPane.rowIndex="1" GridPane.columnIndex="2" styleClass="muted"/>
                    <TextField fx:id="usernameField" GridPane.rowIndex="1" GridPane.columnIndex="3"/>
                </GridPane>

                <HBox spacing="10">
                    <Button text="Start local server" onAction="#onStartLocalServer" styleClass="secondary-button"/>
                    <Region HBox.hgrow="ALWAYS"/>
                    <Button fx:id="connectButton" text="Connect" onAction="#onConnect" styleClass="primary-button"/>
                    <Button fx:id="disconnectButton" text="Disconnect" onAction="#onDisconnect" styleClass="ghost-button"/>
                </HBox>
            </VBox>

            <VBox spacing="10" styleClass="card" maxWidth="900" VBox.vgrow="ALWAYS">
                <padding>
                    <Insets top="18" right="18" bottom="18" left="18"/>
                </padding>
                <Label text="Messages" styleClass="brand-title"/>
                <ListView fx:id="messagesList" prefHeight="360" VBox.vgrow="ALWAYS"/>

                <HBox spacing="10">
                    <TextField fx:id="messageField" promptText="Type a message..." HBox.hgrow="ALWAYS" onAction="#onSend"/>
                    <Button fx:id="sendButton" text="Send" onAction="#onSend" styleClass="primary-button"/>
                </HBox>
            </VBox>
        </VBox>
    </center>
</BorderPane>

