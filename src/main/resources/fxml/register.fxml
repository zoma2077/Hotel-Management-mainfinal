<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.ChoiceBox?>
<?import javafx.scene.control.DatePicker?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.PasswordField?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.StackPane?>
<?import javafx.scene.layout.VBox?>

<StackPane xmlns="http://javafx.com/javafx"
           xmlns:fx="http://javafx.com/fxml"
           fx:controller="com.cse241.hotel.ui.controller.RegisterController"
           styleClass="auth-pane">
    <VBox alignment="TOP_CENTER" spacing="12" maxWidth="480" styleClass="card">
        <padding>
            <Insets top="28" right="32" bottom="28" left="32"/>
        </padding>

        <Label text="Create account" styleClass="brand-title"/>
        <Label text="Join the Hotel Management System" styleClass="brand-subtitle"/>

        <VBox spacing="6">
            <Label text="Username" styleClass="field-label"/>
            <TextField fx:id="usernameField" promptText="Pick a username"/>
        </VBox>
        <VBox spacing="6">
            <Label text="Password" styleClass="field-label"/>
            <PasswordField fx:id="passwordField" promptText="Min 8 chars, letters and digits"/>
        </VBox>
        <VBox spacing="6">
            <Label text="Date of birth" styleClass="field-label"/>
            <DatePicker fx:id="dobPicker" promptText="YYYY-MM-DD" maxWidth="Infinity"/>
        </VBox>
        <HBox spacing="12">
            <VBox spacing="6" HBox.hgrow="ALWAYS">
                <Label text="Starting balance" styleClass="field-label"/>
                <TextField fx:id="balanceField" promptText="0.00"/>
            </VBox>
            <VBox spacing="6" HBox.hgrow="ALWAYS">
                <Label text="Gender" styleClass="field-label"/>
                <ChoiceBox fx:id="genderChoice" maxWidth="Infinity"/>
            </VBox>
        </HBox>
        <VBox spacing="6">
            <Label text="Address" styleClass="field-label"/>
            <TextField fx:id="addressField" promptText="Street, city"/>
        </VBox>
        <VBox spacing="6">
            <Label text="Room preferences (comma separated)" styleClass="field-label"/>
            <TextField fx:id="preferencesField" promptText="e.g. Suite, High floor"/>
        </VBox>

        <Button text="Create account" onAction="#onRegister" defaultButton="true"
                maxWidth="Infinity" styleClass="primary-button"/>

        <HBox alignment="CENTER" spacing="6">
            <Label text="Already a member?" styleClass="muted"/>
            <Button text="Back to sign in" onAction="#onBackToLogin" styleClass="link-button"/>
        </HBox>

        <Label fx:id="statusLabel" styleClass="status-label" wrapText="true"/>
    </VBox>
</StackPane>
